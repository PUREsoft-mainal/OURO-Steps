FROM node:18
WORKDIR /app

# الخطوة 1: نسخ ملفات التعريف (سواء كانت في المجلد الرئيسي أو داخل مجلد server)
# سنستخدم علامة النجمة لضمان الوصول للملف أينما كان
COPY package*.json ./
# إذا كان لديك ملف package.json داخل مجلد server، جرب السطر التالي بدلاً من الأعلى:
# COPY server/package*.json ./ 

# الخطوة 2: تثبيت المكتبات
RUN npm install

# الخطوة 3: نسخ كل الملفات
COPY . .

# الخطوة 4: الإعدادات الخاصة بـ Hugging Face
ENV PORT=7860
EXPOSE 7860

# الخطوة 5: التشغيل (هنا الاحتمال الأكبر للنجاح)
# سنستخدم أمر يحاول تشغيل الملف سواء كان في المجلد الرئيسي أو المجلد الفرعي
CMD ["node", "server/server.js"] || ["node", "server.js"]
